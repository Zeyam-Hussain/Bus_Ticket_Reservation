{
  "version": 2,
  "functions": {
    "bus_backend/api/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "destination": "/bus_backend/api/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/bus_frontend/dist/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "/bus_frontend/dist/index.html"
    }
  ]
}