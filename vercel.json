{
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/api/user/login",
      "dest": "/api/user/login.php"
    },
    {
      "src": "/api/user/register",
      "dest": "/api/user/register.php"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/bus_frontend/dist/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "/bus_frontend/dist/index.html"
    }
  ]
}