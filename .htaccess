<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Protect .env file
  <Files ".env">
    Order allow,deny
    Deny from all
  </Files>

  # Don't rewrite for actual files or directories (allows API and assets to work)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Redirect all other requests to index.html for React Router
  RewriteRule ^ index.html [L]
</IfModule>

